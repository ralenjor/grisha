#!/bin/bash

# --- Project KARKAS: Grisha Standalone Launcher ---
# Purpose: Environment activation and API initialization

# 1. Define Paths
VENV_PATH="./venv"  # Adjust this if your virtual env is named differently
MAIN_SCRIPT="grisha_query.py"

echo "======================================================="
echo "        INITIALIZING GRISHA: TACTICAL ADVISOR          "
echo "======================================================="

# 2. Check for Virtual Environment
if [ -d "$VENV_PATH" ]; then
    echo "[*] Activating virtual environment..."
    source "$VENV_PATH/bin/activate"
else
    echo "[!] Error: Virtual environment not found at $VENV_PATH"
    echo "    Please run your setup script first."
    exit 1
fi

# 3. Check for API Key
if [ -z "$OPENAI_API_KEY" ]; then
    echo "[!] OpenAI API Key not detected in environment variables."
    echo -n "Please enter your API Key (hidden): "
    read -s API_INPUT
    export OPENAI_API_KEY=$API_INPUT
    echo -e "\n[+] API Key set for this session."
fi

# 4. Launch the Chatbot
if [ -f "$MAIN_SCRIPT" ]; then
    echo "[*] Connecting to Knowledge Base (19,000 Chunks)..."
    echo "[*] System Ready."
    echo "-------------------------------------------------------"
    python3 "$MAIN_SCRIPT"
else
    echo "[!] Error: $MAIN_SCRIPT not found in current directory."
    exit 1
fi

# 5. Cleanup
deactivate
echo "-------------------------------------------------------"
echo "[*] Grisha Session Terminated."
