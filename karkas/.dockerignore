# Docker ignore file for KARKAS

# Build artifacts
build/
*.o
*.a
*.so
*.pyc
__pycache__/
*.egg-info/
dist/
*.egg

# Development files
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
*~

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Virtual environments
venv/
.venv/
env/
.env/

# IDE and editor files
*.sublime-project
*.sublime-workspace

# Documentation
*.md
!README.md
docs/

# Large data files (mount as volumes instead)
data/terrain/*.gpkg
data/terrain/raw/

# Docker files (don't need to copy these into the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Local development
.env.local
.env.*.local
*.local.yaml
*.local.yml

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# CMake build directories (we only need source)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# OS files
.DS_Store
Thumbs.db
