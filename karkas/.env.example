# KARKAS Environment Configuration
# Copy this file to .env and customize as needed
#
# All configuration options use sensible defaults and are optional.
# Environment variables override .env file values.

# =============================================================================
# Server Configuration
# =============================================================================

# Server bind address (default: 0.0.0.0)
KARKAS_HOST=0.0.0.0

# Port for the KARKAS server (default: 8080)
KARKAS_PORT=8080

# Enable debug mode (default: false)
KARKAS_DEBUG=false

# Allowed CORS origins (comma-separated, default: *)
# KARKAS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Request timeout in seconds (default: 30)
KARKAS_REQUEST_TIMEOUT=30

# =============================================================================
# Database Configuration (PostgreSQL/PostGIS)
# =============================================================================

# Enable/disable database persistence (default: false)
# When disabled, game state is kept in memory only
KARKAS_DB_ENABLED=false

# Database connection settings
KARKAS_DB_HOST=localhost
KARKAS_DB_PORT=5432
KARKAS_DB_NAME=karkas
KARKAS_DB_USER=karkas
KARKAS_DB_PASSWORD=karkas

# Connection pool settings
KARKAS_DB_POOL_SIZE=5
KARKAS_DB_MAX_OVERFLOW=10
KARKAS_DB_POOL_TIMEOUT=30
KARKAS_DB_POOL_RECYCLE=1800

# Enable SQL query logging (development only, default: false)
KARKAS_DB_ECHO=false

# Database schema name (default: karkas)
KARKAS_DB_SCHEMA=karkas

# External port for direct database access (Docker only)
KARKAS_DB_EXTERNAL_PORT=5433

# =============================================================================
# Grisha RAG Integration
# =============================================================================

# URL for the Grisha RAG API (default: http://localhost:8000)
GRISHA_API_URL=http://localhost:8000

# API request timeout in seconds (default: 30)
GRISHA_API_TIMEOUT=30

# Maximum search results from RAG (default: 10)
GRISHA_MAX_RESULTS=10

# =============================================================================
# Ollama LLM Configuration
# =============================================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Default LLM model for inference (default: llama3.3:70b)
OLLAMA_MODEL=llama3.3:70b

# LLM inference timeout in seconds (default: 120)
OLLAMA_TIMEOUT=120

# LLM temperature setting (0.0-2.0, default: 0.7)
OLLAMA_TEMPERATURE=0.7

# Maximum tokens in LLM response (default: 2048)
OLLAMA_MAX_TOKENS=2048

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
KARKAS_LOG_LEVEL=INFO

# Log format: 'text' for colored console, 'json' for structured output (default: text)
KARKAS_LOG_FORMAT=text

# Directory for log files (default: logs)
KARKAS_LOG_DIR=logs

# Enable file logging (default: true)
# KARKAS_LOG_TO_FILE=true

# Log file max size in bytes before rotation (default: 10MB)
# KARKAS_LOG_MAX_BYTES=10485760

# Number of backup log files to keep (default: 5)
# KARKAS_LOG_BACKUP_COUNT=5

# =============================================================================
# Path Configuration
# =============================================================================

# Data directory (default: data)
KARKAS_DATA_DIR=data

# Terrain data directory (default: data/terrain)
KARKAS_TERRAIN_DIR=data/terrain

# Scenarios directory (default: data/scenarios)
KARKAS_SCENARIOS_DIR=data/scenarios

# Doctrine files directory (default: data/doctrine)
KARKAS_DOCTRINE_DIR=data/doctrine

# =============================================================================
# Client Configuration
# =============================================================================

# KARKAS server URL for CLI client (default: http://localhost:8080)
KARKAS_SERVER_URL=http://localhost:8080

# Client connection timeout in seconds (default: 10)
KARKAS_CONNECT_TIMEOUT=10

# Client read timeout in seconds (default: 30)
KARKAS_READ_TIMEOUT=30
