# KARKAS Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Server Configuration
# =============================================================================

# Port for the KARKAS server
KARKAS_PORT=8080

# =============================================================================
# Database Configuration
# =============================================================================

# Enable/disable database persistence
KARKAS_DB_ENABLED=true

# Database connection settings
KARKAS_DB_HOST=db
KARKAS_DB_PORT=5432
KARKAS_DB_NAME=karkas
KARKAS_DB_USER=karkas
KARKAS_DB_PASSWORD=karkas

# External port for direct database access (development only)
KARKAS_DB_EXTERNAL_PORT=5433

# Connection pool settings
KARKAS_DB_POOL_SIZE=5
KARKAS_DB_MAX_OVERFLOW=10

# Enable SQL query logging (development only)
KARKAS_DB_ECHO=false

# =============================================================================
# Grisha AI Integration
# =============================================================================

# URL for the Grisha RAG API
GRISHA_API_URL=http://localhost:8000

# Ollama host for LLM inference
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
KARKAS_LOG_LEVEL=INFO

# Log format: 'text' for colored console, 'json' for structured output
KARKAS_LOG_FORMAT=text

# Directory for log files (relative to working directory)
KARKAS_LOG_DIR=logs

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode
KARKAS_DEBUG=false
